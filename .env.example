# ─────────────────────────────────────────────
#  firmware-mgnl-service — Environment Variables
#  Copy to .env and fill in your values.
# ─────────────────────────────────────────────

# Port the HTTP server listens on.
PORT=3000

# Absolute or relative path to the directory containing service sub-folders.
# Structure: <PACKAGE_STORAGE>/<service-name>/<service-name>_<version>.tgz
# Default: ./storage
PACKAGE_STORAGE=./storage

# API key required in the x-api-key header for every request.
# Leave blank to disable API key protection (not recommended in production).
API_KEY=change-me-to-a-strong-random-secret
